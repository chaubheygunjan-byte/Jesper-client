{% schema %}
{
  "name": "Premium Collection",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "PREMIUM UDVALG"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Udvalgte Modeller"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "View All Link Text",
      "default": "Se alle produkter"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "View All Link URL"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to Show",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle Color",
      "default": "#6b7280"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#0a1628"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link Color",
      "default": "#0a1628"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card Background",
      "default": "#f5f7fa"
    },
    {
      "type": "color",
      "id": "badge_bg",
      "label": "Badge Background",
      "default": "#0f2a4a"
    },
    {
      "type": "color",
      "id": "badge_text",
      "label": "Badge Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Product Title Color",
      "default": "#0a1628"
    },
    {
      "type": "color",
      "id": "desc_color",
      "label": "Description Color",
      "default": "#6b7280"
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price Color",
      "default": "#0a1628"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom CSS Class",
      "placeholder": "e.g. premium-v2"
    }
  ],
  "blocks": [
    {
      "type": "product_override",
      "name": "Product Badge",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product (optional, overrides collection)"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge Text",
          "placeholder": "e.g. Nyhed, Udsalg, Populær"
        },
        {
          "type": "text",
          "id": "custom_desc",
          "label": "Custom Description",
          "placeholder": "Overrides product description"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Premium Collection"
    }
  ]
}
{% endschema %}

<section class="premium-collection {{ section.settings.custom_class }} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %} " style="background-color: {{ section.settings.bg_color }}; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="premium-collection__container">

    <div class="premium-collection__header">
      <div class="premium-collection__titles">
        {% if section.settings.subtitle != blank %}
          <span class="premium-collection__subtitle" style="color: {{ section.settings.subtitle_color }};">
            {{ section.settings.subtitle }}
          </span>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="premium-collection__heading" style="color: {{ section.settings.heading_color }};">
            {{ section.settings.heading }}
          </h2>
        {% endif %}
      </div>
      {% if section.settings.link_text != blank %}
        <a href="{{ section.settings.link_url | default: '#' }}" class="premium-collection__link" style="color: {{ section.settings.link_color }};">
          {{ section.settings.link_text }}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </a>
      {% endif %}
    </div>

    <div class="premium-collection__grid">
      {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
          {% assign prod = block.settings.product %}
          {% if prod != blank %}
            <div class="premium-card" {{ block.shopify_attributes }}>
              <a href="{{ prod.url }}" class="premium-card__link">
                <div class="premium-card__image-wrap" style="background-color: {{ section.settings.card_bg }};">
                  {% if block.settings.badge != blank %}
                    <span class="premium-card__badge" style="background-color: {{ section.settings.badge_bg }}; color: {{ section.settings.badge_text }};">
                      {{ block.settings.badge }}
                    </span>
                  {% endif %}
                  {% if prod.featured_image %}
                    <img
                      src="{{ prod.featured_image | image_url: width: 600 }}"
                      srcset="{{ prod.featured_image | image_url: width: 300 }} 300w, {{ prod.featured_image | image_url: width: 600 }} 600w"
                      sizes="(max-width: 768px) 90vw, 360px"
                      alt="{{ prod.featured_image.alt | default: prod.title }}"
                      loading="lazy"
                      width="600"
                      height="{{ 600 | divided_by: prod.featured_image.aspect_ratio | round }}"
                    >
                  {% else %}
                    {{ 'product-1' | placeholder_svg_tag: 'premium-card__placeholder' }}
                  {% endif %}
                </div>
                <div class="premium-card__info">
                  <h3 class="premium-card__title" style="color: {{ section.settings.title_color }};">{{ prod.title }}</h3>
                  <p class="premium-card__desc" style="color: {{ section.settings.desc_color }};">
                    {% if block.settings.custom_desc != blank %}
                      {{ block.settings.custom_desc }}
                    {% else %}
                      {{ prod.metafields.custom.short_description | default: prod.type }}
                    {% endif %}
                  </p>
                  <p class="premium-card__price" style="color: {{ section.settings.price_color }};">
                    {{ prod.price | money }}
                  </p>
                </div>
              </a>
            </div>
          {% endif %}
        {% endfor %}

      {% elsif section.settings.collection != blank %}
        {% for prod in section.settings.collection.products limit: section.settings.products_to_show %}
          <div class="premium-card">
            <a href="{{ prod.url }}" class="premium-card__link">
              <div class="premium-card__image-wrap" style="background-color: {{ section.settings.card_bg }};">
                {% if prod.featured_image %}
                  <img
                    src="{{ prod.featured_image | image_url: width: 600 }}"
                    srcset="{{ prod.featured_image | image_url: width: 300 }} 300w, {{ prod.featured_image | image_url: width: 600 }} 600w"
                    sizes="(max-width: 768px) 90vw, 360px"
                    alt="{{ prod.featured_image.alt | default: prod.title }}"
                    loading="lazy"
                    width="600"
                    height="{{ 600 | divided_by: prod.featured_image.aspect_ratio | round }}"
                  >
                {% else %}
                  {{ 'product-1' | placeholder_svg_tag: 'premium-card__placeholder' }}
                {% endif %}
              </div>
              <div class="premium-card__info">
                <h3 class="premium-card__title" style="color: {{ section.settings.title_color }};">{{ prod.title }}</h3>
                <p class="premium-card__desc" style="color: {{ section.settings.desc_color }};">{{ prod.type }}</p>
                <p class="premium-card__price" style="color: {{ section.settings.price_color }};">{{ prod.price | money }}</p>
              </div>
            </a>
          </div>
        {% endfor %}

      {% else %}
        {% for i in (1..3) %}
          <div class="premium-card">
            <div class="premium-card__link">
              <div class="premium-card__image-wrap" style="background-color: {{ section.settings.card_bg }};">
                {{ 'product-1' | placeholder_svg_tag: 'premium-card__placeholder' }}
              </div>
              <div class="premium-card__info">
                <h3 class="premium-card__title" style="color: {{ section.settings.title_color }};">Product Title</h3>
                <p class="premium-card__desc" style="color: {{ section.settings.desc_color }};">Product description</p>
                <p class="premium-card__price" style="color: {{ section.settings.price_color }};">0,00 DKK</p>
              </div>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>

  </div>
</section>

<style>
  .premium-collection {
    overflow: hidden;
  }

  .premium-collection__container {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 60px;
  }

  .premium-collection__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 36px;
    gap: 20px;
  }

  .premium-collection__titles {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .premium-collection__subtitle {
    color: #446279;
    font-family: "Plus Jakarta Sans";
    font-size: 12px;
    font-style: normal;
    font-weight: 700;
    line-height: 16px; /* 133.333% */
    letter-spacing: 1.2px;
    text-transform: uppercase;
  }

  .premium-collection__heading {
    font-family: "Manrope", sans-serif;
    font-size: clamp(24px, 3vw, 36px);
    color: #000E27;
    font-family: Manrope;
    font-style: normal;
    font-weight: 800;
    line-height: 40px; /* 111.111% */
        margin: 0;
  }

  .premium-collection__link {
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
    transition: opacity 0.2s;
    color: #000E27;
    font-family: "Plus Jakarta Sans";
    font-size: 16px;
    font-style: normal;
    font-weight: 700;
    line-height: 24px; /* 150% */
    border-bottom: 2px solid rgba(0, 14, 39, 0.20);
    padding-bottom: 5px;
    }

  .premium-collection__link:hover {
    opacity: 0.7;
  }

  .premium-collection__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .premium-card__link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .premium-card__image-wrap {
    border-radius: 16px;
    padding: 24px;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 1 / 1;
    margin-bottom: 16px;
  }

  .premium-card__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.3s ease;
  }

  .premium-card:hover .premium-card__image-wrap img {
    transform: scale(1.05);
  }

  .premium-card__badge {
    position: absolute;
    top: 16px;
    left: 16px;
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    padding: 6px 14px;
    border-radius: 50px;
    z-index: 1;
  }

  .premium-card__placeholder {
    width: 100%;
    height: 100%;
  }

  .premium-card__info {
    padding: 0 4px;
  }

.premium-card__title {
    font-family: Manrope;
    font-size: 18px;
    font-style: normal;
    font-weight: 700;
    line-height: 28px; /* 155.556% */
    margin:0;
    letter-spacing: 0;
  }

  .premium-card__desc {
    font-family: "Plus Jakarta Sans", sans-serif;
    margin: 5px 0 12px;
    font-size: 14px;
    font-style: normal;
    font-weight: 400;
    line-height: 20px; /* 142.857% */
  }

p.premium-card__price {
    font-family: "Plus Jakarta Sans";
    font-size: 16px;
    font-style: normal;
    font-weight: 700;
    line-height: 24px; /* 150% */
    margin:0 ;
  }

  /* Tablet */
  @media (max-width: 992px) {
    .premium-collection__container {
      padding: 0 30px;
    }

    .premium-collection__grid {
      gap: 16px;
    }
  }

  /* Mobile */
  @media (max-width: 768px) {
    .premium-collection__container {
      padding: 0 20px;
    }


    .premium-collection__grid {
      gap: 10px;
    }
  }

  @media (max-width: 767px) {
   .premium-collection__grid {
      grid-template-columns: 1fr;
      gap: 24px;
      max-width: 400px;
      margin: 0 auto;
    }
    
    .premium-collection__header {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
      margin-bottom: 24px;
    }
  }
</style>