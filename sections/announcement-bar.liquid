{% comment %}
  Custom Announcement Bar for Wallin Shoes
  File: sections/announcement-bar.liquid
  
  Replace the entire content of your Dawn theme's 
  sections/announcement-bar.liquid with this code.
  
  IMPORTANT: Add Font Awesome 5 to your theme.
  In layout/theme.liquid, add inside <head>:
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
{% endcomment %}

<style>
  .wallin-announcement-bar {
    background-color: #1a2744;
    color: #ffffff;
    padding: 10px 60px;
    font-size: 14px;
    letter-spacing: 0.02em;
  }

  .wallin-announcement-bar__inner {
    max-width: 100%;
    margin: 0 auto;
    padding: 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .wallin-announcement-bar__item {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #ffffff;
    font-weight: 400;
    font-family: "Plus Jakarta Sans";
    font-size:14px;
  }

  .wallin-announcement-bar__icon {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    font-size: 16px;
  }

  /* Mobile: stack or scroll */
  @media screen and (max-width: 749px) {
    .wallin-announcement-bar {
      padding: 0 20px;
    }

    .wallin-announcement-bar__inner {
      justify-content: center;
      gap: 20px;
      flex-wrap: wrap;
    }

    .wallin-announcement-bar__item {
      font-size: 12px;
    }

    .wallin-announcement-bar__icon {
      font-size: 14px;
    }
  }
</style>

<div class="wallin-announcement-bar">
  <div class="wallin-announcement-bar__inner">
    
    {%- for block in section.blocks -%}
      <div class="wallin-announcement-bar__item" {{ block.shopify_attributes }}>
        <span class="wallin-announcement-bar__icon">
          <i aria-hidden="true" class="{{ block.settings.icon_class }}"></i>
        </span>
        <span>{{ block.settings.text }}</span>
      </div>
    {%- endfor -%}

  </div>
</div>

{% schema %}
{
  "name": "Announcement Bar",
  "max_blocks": 4,
  "class": "announcement-bar-section",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "Announcement text",
          "label": "Text"
        },
        {
          "type": "select",
          "id": "icon_class",
          "label": "Icon",
          "default": "fas fa-check",
          "options": [
            { "value": "fas fa-check", "label": "Checkmark ✔" },
            { "value": "fas fa-shipping-fast", "label": "Fast Shipping 🚚" },
            { "value": "fas fa-sync-alt", "label": "Sync / Return ↺" },
            { "value": "fas fa-truck", "label": "Truck" },
            { "value": "fas fa-lock", "label": "Lock 🔒" },
            { "value": "fas fa-heart", "label": "Heart ❤" },
            { "value": "fas fa-star", "label": "Star ⭐" },
            { "value": "fas fa-tag", "label": "Tag 🏷" },
            { "value": "fas fa-gift", "label": "Gift 🎁" },
            { "value": "fas fa-phone", "label": "Phone 📞" },
            { "value": "fas fa-credit-card", "label": "Credit Card 💳" },
            { "value": "fas fa-shield-alt", "label": "Shield 🛡" }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar",
      "blocks": [
        {
          "type": "announcement",
          "settings": {
            "text": "Gratis fragt",
            "icon_class": "fas fa-check"
          }
        },
        {
          "type": "announcement",
          "settings": {
            "text": "1-3 dages levering",
            "icon_class": "fas fa-shipping-fast"
          }
        },
        {
          "type": "announcement",
          "settings": {
            "text": "14 dages returret",
            "icon_class": "fas fa-sync-alt"
          }
        }
      ]
    }
  ]
}
{% endschema %}