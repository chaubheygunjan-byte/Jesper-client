
<style>
.healthy-shoes {
  padding: 50px 0;
  text-align: center;
}

.healthy-shoes .container {
  max-width: 1310px;
  margin: 0 auto;
  padding:0 15px;
  padding-bottom:100px;
  border-bottom:1px solid #000;
}

.section-heading {
    color: #000;
    font-family: "Lato", Sans-serif;
    font-weight: 600;
    font-size: 42px;
    text-transform: uppercase;
    line-height: 1.4em;
    text-align: center;
    margin: 0 0 20px;
}

.features {
  display: grid;
  grid-template-columns: 1fr;
  gap: 30px;
}

.feature-item h3 {
    font-size: 28px;
    text-transform: uppercase;
    letter-spacing: 1px;
    line-height: 1.2em;
    color: #000;
    font-weight: 700;
    text-align: center;
    margin: 20px 0;
}

.feature-item p {
    font-size: 14px;
    color: #000;
    margin-top: 10px;
    line-height: 22px;
    font-weight: 400;
    letter-spacing: 0;
    text-align: left;
}

.icon-circle {
  width: 100%;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
}

.icon-circle img {
  max-width: 100%;
}


.block_desc {
    padding: 0 50px 40px;
}

/* Desktop */
@media (min-width: 768px) {
  .features {
    grid-template-columns: repeat(3, 1fr);
  }

}

@media (max-width: 1024px) {
  .block_desc {
    padding: 0 ;
}
}
</style>


<section class="healthy-shoes {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
  <div class="container">
    
    <h2 class="section-heading">{{ section.settings.heading }}</h2>

    <div class="features">
      {% for block in section.blocks %}
        <div class="feature-item">
          
          <div class="icon-circle">
            {% if block.settings.icon %}
              <img src="{{ block.settings.icon | image_url: width: 1024 }}" alt="">
            {% endif %}
          </div>
          <div class="block_desc">
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.description }}</p>
            </div>
        </div>
      {% endfor %}
    </div>

    {% if section.settings.button_text != blank %}
      <a href="{{ section.settings.button_link }}" class="cta-btn">
        {{ section.settings.button_text }}
      </a>
    {% endif %}

  </div>
</section>


{% schema %}
{
  "name": "Healthy Shoes",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "HEALTHY SHOES"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "MORE ABOUT THE TECHNOLOGY"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "VOLUME"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Add your content here."
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Healthy Shoes"
    }
  ]
}
{% endschema %}