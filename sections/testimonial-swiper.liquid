{% comment %}
  Testimonial Swiper Slider Section
  Add this as sections/testimonial-swiper.liquid
{% endcomment %}

{{ 'section-testimonial-swiper.css' | asset_url | stylesheet_tag }}

<div class="testimonial-section" id="testimonial-section-{{ section.id }}">
  <div class="testimonial-section__container">
    {% if section.settings.heading != blank %}
      <h2 class="testimonial-section__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="swiper testimonial-swiper-{{ section.id }}">
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          <div class="swiper-slide" {{ block.shopify_attributes }}>
            <div class="testimonial-card">
              <div class="testimonial-card__bubble">
                <p class="testimonial-card__text">{{ block.settings.testimonial }}</p>
                <div class="testimonial-card__bubble-arrow"></div>
              </div>
              <p class="testimonial-card__author">{{ block.settings.author }}</p>
            </div>
          </div>
        {% endfor %}
      </div>

    </div>
    
      <div class="swiper-button-prev testimonial-nav-prev slide_arrow"><i aria-hidden="true" class="eicon-chevron-left"></i></div>
      <div class="swiper-button-next testimonial-nav-next slide_arrow"><i aria-hidden="true" class="eicon-chevron-right"></i></div>
  </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<style>
.swiper-button-prev.testimonial-nav-prev.slide_arrow {
    left: -20px;
}
.swiper-button-next.testimonial-nav-next.slide_arrow {
    right: -20px;
}
  .slide_arrow i {
    color: #eeeeeee6;
}
  .testimonial-section {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
    overflow: hidden;
  }
 .testimonial-section  .slide_arrow {
    top: 50%;
}
  .testimonial-section__container {
    max-width: 95%;
    margin: 0 auto;
    padding: 0 20px;
    position:relative;
  }

  .testimonial-section__heading {
    color: #000;
    font-size: 40px;
    text-transform: uppercase;
    font-family: "Lato", Sans-serif;
    font-weight: 400;
    line-height: 1.25em;
    margin: 0 0 40px;
    text-align: center;
  }

  .testimonial-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 10px 20px;
  }

  .testimonial-card__bubble {
    background-color: {{ section.settings.bubble_color }};
    border-radius: 50px;
    padding: 20px;
    position: relative;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    letter-spacing: 0;
  }

  .testimonial-card__bubble::after {
    left: 50%;
    transform: translateX(-50%) scaleX(.75) rotate(45deg);
    background-color: {{ section.settings.bubble_color }};
    top: calc(100% - 7px);
    content: "";
    display: block;
    width: 14px;
    height: 14px;
    position: absolute;
    border-width: 0;
    box-sizing: content-box;
  }

  .testimonial-card__text {
    font-family: "Prompt", Sans-serif;
    font-size: 14px;
    font-weight: 400;
    font-style: italic;
    color: #000;
    text-align: center;
    margin: 0;
    line-height: 21px;
  }

  .testimonial-card__author {
    margin: 21px 0 0;
    font-family: "Lato", Sans-serif;
    font-size: 16px;
    font-weight: bold;
    color: {{ section.settings.heading_color }};
    text-align: center;
  }

  /* Swiper nav arrows — thin chevrons matching screenshot */
  .testimonial-nav-prev,
  .testimonial-nav-next {
    width: auto;
    height: auto;
    margin-top: 0;
    top: 40%;
    transform: translateY(-50%);
    background: none;
    border: none;
    border-radius: 0;
    box-shadow: none;
  }

  .testimonial-nav-prev::after,
  .testimonial-nav-next::after {
    font-family: inherit;
    font-size: 48px;
    font-weight: 200;
    color: #aaa;
    transition: color 0.2s;
  }

  .testimonial-nav-prev::after {
    content: '‹';
  }

  .testimonial-nav-next::after {
    content: '›';
  }

  .testimonial-nav-prev:hover::after,
  .testimonial-nav-next:hover::after {
    color: #555;
  }

  .swiper-button-prev.testimonial-nav-prev {
    left: 0;
  }

  .swiper-button-next.testimonial-nav-next {
    right: 0;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .testimonial-card__bubble {
      padding: 20px 25px;
      min-height: 140px;
    }

    .testimonial-card__text {
      font-size: 13px;
    }

    .testimonial-nav-prev::after,
    .testimonial-nav-next::after {
      font-size: 36px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    new Swiper('.testimonial-swiper-{{ section.id }}', {
      slidesPerView: 1,
      spaceBetween: 20,
      grabCursor: true,
      loop: {{ section.settings.loop }},
      autoplay: {% if section.settings.autoplay %}{ delay: {{ section.settings.autoplay_speed | times: 1000 }}, disableOnInteraction: false }{% else %}false{% endif %},
      navigation: {
        nextEl: '.testimonial-nav-next',
        prevEl: '.testimonial-nav-prev',
      },
      breakpoints: {
        640: {
          slidesPerView: 2,
          spaceBetween: 25,
        },
        1024: {
          slidesPerView: 3,
          spaceBetween: 30,
        },
      },
    });
  });
</script>

{% schema %}
{
  "name": "Testimonial Swiper",
  "tag": "section",
  "class": "testimonial-swiper-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "THIS IS WHAT OTHER CUSTOMERS SAY ABOUT OUR SHOES"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "bubble_color",
      "label": "Bubble Color",
      "default": "#f5c6d0"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Autoplay Speed (seconds)",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 5
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop Slides",
      "default": true
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 50,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 50,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "testimonial",
          "label": "Testimonial Text",
          "default": "Really good shoes to walk in. I have wide feet, so the size is just right. They are also good to wear on longer trips. I would definitely recommend it."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author Name",
          "default": "Customer Name"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonial Swiper",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "testimonial": "Really good shoes to walk in. I have wide feet, so the size is just right. They are also good to wear on longer trips – I have just been on vacation with a travel time of 26 hours – almost without taking my shoes off – except for a short shower. I stand up a lot at work, and the shoe is really good there too. I would definitely recommend it. I hope you make some sandals of the same good quality.",
            "author": "Peter Autrup"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "testimonial": "The Wallin shoe is absolutely one of the best we have tried. We are very happy with them. The shoes are fairly easy to put on and fit well. The foot feels good. The shoe has helped and we walk more upright with our backs. We have recommended the shoe to several people who were not satisfied with the footwear they had, and we will do so again at any time.",
            "author": "Jette & Soren Rosenberg"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "testimonial": "The Wallin shoe is the only shoe I can walk in! There are no seams that press in the wrong places and my feet don't hurt because of the rounded toe/sole. The shoe has definitely helped me and I recommend the shoe to others who have arthritis in their feet.",
            "author": "Jette Drewsen Madsen"
          }
        }
      ]
    }
  ]
}
{% endschema %}