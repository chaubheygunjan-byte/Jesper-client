{% schema %}
{
  "name": "Features Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Videnskaben Bag Komforten"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#0a1628"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card Background",
      "default": "#f5f7fa"
    },
    {
      "type": "color",
      "id": "icon_bg",
      "label": "Icon Background",
      "default": "#e8f0fe"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon Color",
      "default": "#0f2a4a"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#0a1628"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#6b7280"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom CSS Class",
      "placeholder": "e.g. features-v2"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Volume"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Ekstra plads til tæerne sikrer naturlig bevægelighed og reducerer trykpunkter gennem hele dagen."
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "shoe",
          "options": [
            { "value": "shoe", "label": "Shoe / Volume" },
            { "value": "sole", "label": "Sole / Gangesål" },
            { "value": "insole", "label": "Insole / Indlægssåler" },
            { "value": "heart", "label": "Heart" },
            { "value": "shield", "label": "Shield" },
            { "value": "star", "label": "Star" }
          ]
        },
        {
          "type": "image_picker",
          "id": "custom_icon",
          "label": "Custom Icon (overrides selected icon)"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Features Grid",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "Volume",
            "description": "Ekstra plads til tæerne sikrer naturlig bevægelighed og reducerer trykpunkter gennem hele dagen.",
            "icon": "shoe"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Gangesål",
            "description": "Vores unikke rocker-sole aflaster forfodens og fremmer en naturlig rullende gangbevægelse.",
            "icon": "sole"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Udtagelige Indlægssåler",
            "description": "Nem tilpasning til dine specifikke behov - udskift sålen til at gå på kompromis med skons pasform eller æstetik.",
            "icon": "insole"
          }
        }
      ]
    }
  ]
}
{% endschema %}

<section class="features-section {{ section.settings.custom_class }} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" style="background-color: {{ section.settings.bg_color }}; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="features-section__container">
    {% if section.settings.heading != blank %}
      <h2 class="features-section__heading" style="color: {{ section.settings.heading_color }};">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    <div class="features-section__grid">
      {% for block in section.blocks %}
        <div class="features-card" style="background-color: {{ section.settings.card_bg }};" {{ block.shopify_attributes }}>
          <div class="features-card__icon" style="background-color: {{ section.settings.icon_bg }};">
            {% if block.settings.custom_icon %}
              <img
                src="{{ block.settings.custom_icon | image_url: width: 80 }}"
                alt="{{ block.settings.title }}"
                width="32"
                height="32"
                loading="lazy"
              >
            {% else %}
              {% case block.settings.icon %}
                {% when 'shoe' %}
                 <svg xmlns="http://www.w3.org/2000/svg" width="25" height="15" viewBox="0 0 25 15" fill="none">
  <path d="M2.5 15C1.8125 15 1.22396 14.7552 0.734375 14.2656C0.244792 13.776 0 13.1875 0 12.5V2.5C0 1.8125 0.244792 1.22396 0.734375 0.734375C1.22396 0.244792 1.8125 0 2.5 0H22.5C23.1875 0 23.776 0.244792 24.2656 0.734375C24.7552 1.22396 25 1.8125 25 2.5V12.5C25 13.1875 24.7552 13.776 24.2656 14.2656C23.776 14.7552 23.1875 15 22.5 15H2.5ZM2.5 12.5H22.5V2.5H18.75V7.5H16.25V2.5H13.75V7.5H11.25V2.5H8.75V7.5H6.25V2.5H2.5V12.5ZM6.25 7.5H8.75H6.25ZM11.25 7.5H13.75H11.25ZM16.25 7.5H18.75H16.25Z" fill="#000E27"/>
</svg>
                {% when 'sole' %}
                  <svg xmlns="http://www.w3.org/2000/svg" width="25" height="25" viewBox="0 0 25 25" fill="none">
  <path d="M12.5 25C10.7708 25 9.14583 24.6719 7.625 24.0156C6.10417 23.3594 4.78125 22.4688 3.65625 21.3438C2.53125 20.2188 1.64062 18.8958 0.984375 17.375C0.328125 15.8542 0 14.2292 0 12.5C0 11.6042 0.09375 10.724 0.28125 9.85938C0.46875 8.99479 0.739583 8.15625 1.09375 7.34375L3.03125 9.28125C2.86458 9.82292 2.73438 10.3594 2.64062 10.8906C2.54688 11.4219 2.5 11.9583 2.5 12.5C2.5 15.2917 3.46875 17.6562 5.40625 19.5938C7.34375 21.5312 9.70833 22.5 12.5 22.5C15.2917 22.5 17.6562 21.5312 19.5938 19.5938C21.5312 17.6562 22.5 15.2917 22.5 12.5C22.5 9.70833 21.5312 7.34375 19.5938 5.40625C17.6562 3.46875 15.2917 2.5 12.5 2.5C11.9375 2.5 11.3906 2.54688 10.8594 2.64062C10.3281 2.73438 9.80208 2.86458 9.28125 3.03125L7.375 1.125C8.20833 0.75 9.04167 0.46875 9.875 0.28125C10.7083 0.09375 11.5833 0 12.5 0C14.2292 0 15.8542 0.328125 17.375 0.984375C18.8958 1.64062 20.2188 2.53125 21.3438 3.65625C22.4688 4.78125 23.3594 6.10417 24.0156 7.625C24.6719 9.14583 25 10.7708 25 12.5C25 14.2292 24.6719 15.8542 24.0156 17.375C23.3594 18.8958 22.4688 20.2188 21.3438 21.3438C20.2188 22.4688 18.8958 23.3594 17.375 24.0156C15.8542 24.6719 14.2292 25 12.5 25ZM4.375 6.25C3.85417 6.25 3.41146 6.06771 3.04688 5.70312C2.68229 5.33854 2.5 4.89583 2.5 4.375C2.5 3.85417 2.68229 3.41146 3.04688 3.04688C3.41146 2.68229 3.85417 2.5 4.375 2.5C4.89583 2.5 5.33854 2.68229 5.70312 3.04688C6.06771 3.41146 6.25 3.85417 6.25 4.375C6.25 4.89583 6.06771 5.33854 5.70312 5.70312C5.33854 6.06771 4.89583 6.25 4.375 6.25Z" fill="#000E27"/>
</svg>
                {% when 'insole' %}
                 <svg xmlns="http://www.w3.org/2000/svg" width="23" height="24" viewBox="0 0 23 24" fill="none">
  <path d="M11.25 23.8125L0 15.0625L2.0625 13.5L11.25 20.625L20.4375 13.5L22.5 15.0625L11.25 23.8125ZM11.25 17.5L0 8.75L11.25 0L22.5 8.75L11.25 17.5ZM11.25 14.3125L18.4375 8.75L11.25 3.1875L4.0625 8.75L11.25 14.3125Z" fill="#000E27"/>
</svg>
                {% when 'heart' %}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="{{ section.settings.icon_color }}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                  </svg>
                {% when 'shield' %}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="{{ section.settings.icon_color }}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                  </svg>
                {% when 'star' %}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="{{ section.settings.icon_color }}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                  </svg>
              {% endcase %}
            {% endif %}
          </div>
          <h3 class="features-card__title" style="color: {{ section.settings.title_color }};">
            {{ block.settings.title }}
          </h3>
          <p class="features-card__text" style="color: {{ section.settings.text_color }};">
            {{ block.settings.description }}
          </p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .features-section {
    overflow: hidden;
  }

  .features-section__container {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 60px;
  }

  .features-section__heading {
    font-size: clamp(32px, 32px, 36px);
    color: #000E27;
    text-align: center;
    font-family: Manrope;
    font-style: normal;
    font-weight: 800;
    line-height: 40px; /* 111.111% */
    letter-spacing: -0.9px;
    margin:0 0 70px;
    position:relative;
  }
h2.features-section__heading::after {
    width: 80px;
    height: 4px;
    position: absolute;
    left: 0;
    right: 0;
    border-radius: 9999px;
    background: #000E27;
    content: "";
    margin: 0 auto;
    bottom: -18px;
}
  .features-section__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap:32px;
  }

  .features-card {
    border-radius: 16px;
    padding: 32px 28px;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .features-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
  }

  .features-card__icon {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    border-radius: 9999px;
  }

  .features-card__icon img {
    width: 28px;
    height: 28px;
    object-fit: contain;
  }

  .features-card__title {
    color: #000E27;
    font-family: Manrope;
    font-size: 20px;
    font-style: normal;
    font-weight: 700;
    line-height: 28px; /* 140% */
    margin:20px 0 15px;
  }

  .features-card__text {
    color: #44474F;
    font-family: "Plus Jakarta Sans";
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    max-width: 300px;
    line-height: 26px;
    letter-spacing: 0;
        margin: 0;
  }

  /* Tablet */
  @media (max-width: 992px) {
    .features-section__container {
      padding: 0 30px;
    }

    .features-section__grid {
      gap: 16px;
    }

    .features-card {
      padding: 24px 20px;
    }
  }

  /* Mobile */
  @media (max-width: 768px) {
    .features-section__container {
      padding: 0 20px;
    }

    .features-section__grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .features-section__heading {
      margin-bottom: 80px;
    }
    .features-card__text {
      max-width: 100%;
    }


  }
</style>